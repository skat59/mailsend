root = true

[*]
indent_style = tab
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[**.js]
tab_width = 4

[**.coffee]
tab_width = 4

[**.cson]
tab_width = 4

[**.json]
tab_width = 4

[**rc]
tab_width = 4

[**.php]
indent_style = tab
tab_width = 4

[**.yml]
indent_style = space
indent_size = 2
end_of_line = crlf
