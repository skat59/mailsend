style
	|*, *::after, *::before {
	|	box-sizing: border-box;
	|}
	|.clearfix::before, .clearfix::after {
	|	content: "";
	|	display: table;
	|	clear: both;
	|}
	|.emoji {
	|	font-family: 'Tahoma', sans-serif;
	|}
	|.emoji-wrapp .emoji-content {
	|	background-color: white;
	|}
	|.emoji-content .tabs-content h1,
	|.emoji-content .tabs-content h2,
	|.emoji-content .tabs-content h3,
	|.emoji-content .tabs-content h4,
	|.emoji-content .tabs-content h5,
	|.emoji-content .tabs-content h6 {
	|	padding-left: 15px;
	|	padding-right: 15px;
	|	user-select: none;
	|}
	|.emoji-wrapp .emoji-content {
	|	box-shadow: 0 0 1px #000;
	|}
	|.emoji-wrapp .emoji-tabs {
	|	font-family: 'Tahoma', sans-serif;
	|}
	|.emoji-tabs .tabs-item {
	|	display: block;
	|	position: relative;
	|	z-index: 1;
	|	box-shadow: 0 0px 0px 0px #fff;
	|	user-select: none;
	|}
	|.emoji-tabs .tabs-item.active {
	|	z-index: 3;
	|	box-shadow: 0 -2px 4px 0px #ebe8e8;
	|}
	|.emoji-tabs .tabs-item > label {
	|	position: relative;
	|	display: block;
	|	cursor: pointer;
	|	padding: 15px 10px;
	|	position: relative;
	|	border: 1px solid #d6d6d6;
	|}
	|.emoji-tabs .tabs-item > label::after {
	|	content: "";
	|	display: block;
	|	position: absolute;
	|	top: 0;
	|	left: 0;
	|	width: 100%;
	|	height: 100%;
	|	background-color: #f5f5f5;
	|	z-index: -1;
	|}
	|.emoji-tabs .tabs-item.active > label {
	|	border-bottom: 1px solid #fff;
	|}
	|.emoji-tabs .tabs-item.active > label::after {
	|	height: 100%;
	|	background-color: #fff;
	|}
	|.emoji-tabs .tabs-item > label > input {
	|	display: none;
	|}
	|.emoji-content {
	|	position: relative;
	|	z-index: 1;
	|}
	|.emoji-content .tabs-content {
	|	display: none;
	|}
	|.emoji-content .tabs-content.active {
	|	display: block;
	|}
	|.emoji-tabs {
	|	display: flex;
	|	flex-direction: row;
	|	flex-wrap: wrap;
	|	align-items: center;
	|	justify-content: flex-start;
	|	position: relative;
	|	z-index: 3;
	|}
	|.emoji-icons-wrapp {
	|	display: flex;
	|	flex-direction: row;
	|	flex-wrap: wrap;
	|	justify-content: flex-start;
	|	padding-left: 15px;
	|	padding-right: 15px;
	|}
	|.emoji--icon {
	|	position: relative;
	|	display: inline-block;
	|	line-height: 1;
	|	padding: 5px;
	|	border-radius: 4px;
	|	box-shadow: 0 0 1px black;
	|	margin: 5px;
	|	cursor: pointer;
	|	transition: all .3s ease;
